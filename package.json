{
  "name": "bestwork-agent",
  "version": "1.0.0",
  "description": "Best harness engineering for Claude Code. Work like a corporation team, not just a club.",
  "type": "module",
  "bin": {
    "bestwork": "./dist/index.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "skills/",
    "prompts/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsup && node scripts/sync-plugin.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "benchmark": "vitest run benchmarks/"
  },
  "keywords": [
    "claude",
    "claude-code",
    "observability",
    "analytics",
    "tui",
    "agent",
    "monitoring"
  ],
  "author": "rlaope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rlaope/bestwork-agent"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "ink": "^5.1.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.3",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
