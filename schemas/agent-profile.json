{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bestwork agent profile",
  "description": "Schema for agent prompt markdown files in prompts/",
  "type": "object",
  "required": ["id", "role", "name", "specialty"],
  "properties": {
    "id": { "type": "string", "pattern": "^(tech|pm|critic)-[a-z-]+$" },
    "role": { "type": "string", "enum": ["tech", "pm", "critic"] },
    "name": { "type": "string" },
    "specialty": { "type": "string" }
  }
}
